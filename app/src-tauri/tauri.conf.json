{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "sticky",
  "version": "0.1.0",
  "identifier": "com.hori.sticky",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "sticky",
        "width": 1,
        "height": 1,
        "resizable": false,
        "transparent": true,
        "alwaysOnTop": false,
        "decorations": false,
        "visibleOnAllWorkspaces": false,
        "skipTaskbar": true,
        "acceptFirstMouse": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
